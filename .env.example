APP_NAME=ldksyahid-app
APP_ENV=local
APP_KEY=
APP_DEBUG=false
APP_URL=http://127.0.0.1:8000

# CORS: separate multiple domains with a comma
# Example for production: https://www.ldksyah.id,https://ldksyah.id
CORS_ALLOWED_ORIGINS=http://127.0.0.1:8000

# Token API expiration (minutes). Default: 10080 = 7 days
SANCTUM_TOKEN_EXPIRATION=10080

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=ldksyahid_db
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DRIVER=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mail (Brevo SMTP relay)
# Get the SMTP key from Brevo: SMTP & API -> SMTP tab -> Generate SMTP Key.
# MAIL_USERNAME = your Brevo login email; MAIL_PASSWORD = the generated SMTP key.
# MAIL_FROM_ADDRESS must be a verified sender/domain in Brevo.
MAIL_MAILER=smtp
MAIL_HOST=smtp-relay.brevo.com
MAIL_PORT=587
MAIL_USERNAME=your_brevo_login_email_here
MAIL_PASSWORD=your_brevo_smtp_key_here
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=your_verified_sender@example.com
MAIL_FROM_NAME="LDK Syahid"

# Brevo REST API key — used to check daily quota before sending so emails are
# not silently dropped when the free-plan 300/day limit is hit.
# Get it from: SMTP & API -> API Keys tab -> Generate a new API key.
BREVO_API_KEY=xkeysib-your-api-key-here

# Gmail SMTP — used for transactional emails sent synchronously (donation
# invoice, donation success, subscribe/unsubscribe confirmation, form submission
# confirmation). Use a Google App Password, NOT the account password.
# Enable App Passwords at: myaccount.google.com/apppasswords
# GMAIL_FROM_ADDRESS must match GMAIL_USERNAME (Google enforces this).
GMAIL_HOST=smtp.gmail.com
GMAIL_PORT=587
GMAIL_ENCRYPTION=tls
GMAIL_USERNAME=noreplyldksyahid@gmail.com
GMAIL_APP_PASSWORD=your_google_app_password_here
GMAIL_FROM_ADDRESS=noreplyldksyahid@gmail.com
GMAIL_FROM_NAME="LDK Syahid"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1

MIX_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
MIX_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

SWEET_ALERT_TIMER=6000
FILESYSTEM_DRIVER=public

# reCAPTCHA Enterprise (Google Cloud Security Command Center → Fraud Defense)
# RECAPTCHA_TYPE: "score" = invisible score-based (recommended, no user interaction)
#                 "checkbox" = visible "I'm not a robot" checkbox
# RECAPTCHA_SITE_KEY  : Key ID from Fraud Defense dashboard (e.g. 6LcEXRwt...).
# RECAPTCHA_API_KEY   : Google Cloud API key (NOT the legacy secret key).
#                       Create at: console.cloud.google.com → APIs & Services → Credentials.
#                       Must have "reCAPTCHA Enterprise API" enabled.
# RECAPTCHA_PROJECT_ID: Google Cloud project ID (e.g. ukm-ldk-syahid).
# RECAPTCHA_SCORE_THRESHOLD: Risk score cutoff 0.0–1.0 (default 0.5, higher = stricter).
RECAPTCHA_TYPE=score
RECAPTCHA_SITE_KEY=your_enterprise_site_key_here
RECAPTCHA_API_KEY=your_google_cloud_api_key_here
RECAPTCHA_PROJECT_ID=your_google_cloud_project_id_here
RECAPTCHA_SCORE_THRESHOLD=0.5
RECAPTCHA_ENABLED=true

SECRET_KEY_XENDIT=your_xendit_secret_key_here
XENDIT_WEBHOOK_TOKEN=your_xendit_webhook_token_here

# BisaTopup Payment Gateway (Bisabiller backend)
BISATOPUP_USERNAME=your_bisatopup_username
BISATOPUP_PASSWORD_API=your_bisatopup_password_api
BISATOPUP_WIDGET_KEY=your_bisatopup_widget_key
BISATOPUP_ENV=dev
BISATOPUP_BASE_URL_LIVE=https://api.bisabiller.com
BISATOPUP_BASE_URL_DEV=https://api-sandbox.bisabiller.com
BISATOPUP_QRIS_PAYMENT_ID=33
BISATOPUP_ADMIN_FEE=0
BISATOPUP_ENFORCE_CALLBACK_SIGNATURE=false

# 2FA Withdrawal Security
TWO_FA_ALLOWED_USERS=email@gmail.com
TWO_FA_APP_NAME="LDK Syahid Admin"
TWO_FA_DISCREPANCY_THRESHOLD=50000

# Fonnte WhatsApp API
FONNTE_TOKEN=your_fonnte_token_here

# GIPHY API Key
GIPHY_API_KEY=your_key_here
